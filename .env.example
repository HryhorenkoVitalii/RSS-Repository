# SQLite DB file (created on first run)
DATABASE_URL=sqlite:rss_repository.db
BIND_ADDR=127.0.0.1:8080
RUST_LOG=info,rss_repository=info

# API key for authentication (if unset, all endpoints are open)
# API_KEY=change-me-to-a-random-secret

# Base URL for links inside /feed.xml (e.g. SPA during dev)
# PUBLIC_BASE_URL=http://127.0.0.1:5173

# Optional: CORS allow-origin for direct browser calls to the API port. Vite dev uses proxy, so often not needed.
# FRONTEND_ORIGIN=http://127.0.0.1:5173
